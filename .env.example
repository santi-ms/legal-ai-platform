# Legal AI Platform - Environment Variables Example

# ============================================
# Frontend (apps/web)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production
API_URL=http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_PDF_SERVICE_URL=http://localhost:4100
NEXT_PUBLIC_INACTIVITY_MINUTES=30

# ============================================
# Backend API (apps/api)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/legal_ai?schema=public
PORT=4001
FRONTEND_URL=http://localhost:3000

# Email Configuration
# Prioridad de providers: Resend -> Postmark -> SMTP -> Logger fallback
RESEND_API_KEY=re_your-resend-api-key
POSTMARK_SERVER_TOKEN=postmark-server-token
EMAIL_FROM=DocuLex <noreply@tu-dominio.com>

# SMTP opcional (fallback si no hay Resend ni Postmark)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=tu-email@gmail.com
EMAIL_SERVER_PASSWORD=tu-app-password

# Formulario de contacto (apps/web) — usa Resend si está, sino Postmark
# RESEND_API_KEY ya definido arriba
RESEND_FROM_EMAIL=soporte@tu-dominio.com
POSTMARK_FROM_EMAIL=soporte@tu-dominio.com
CONTACT_TO_EMAIL=soporte@tu-dominio.com

# Claude API (reemplaza a OpenAI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Super-Admin Panel — email con acceso exclusivo a /admin
SUPER_ADMIN_EMAIL=tu-email@dominio.com

# ============================================
# PDF Service (apps/pdf)
# ============================================
PDF_OUTPUT_DIR=./pdfs
PORT=4100

# ============================================
# Production (Vercel/Railway)
# ============================================
# Para Vercel (Frontend):
# - NEXTAUTH_URL debe ser tu dominio de Vercel
# - NEXTAUTH_SECRET debe ser un valor aleatorio seguro
# - NEXT_PUBLIC_API_URL debe ser la URL de Railway API
# - NEXT_PUBLIC_PDF_SERVICE_URL debe ser la URL de Railway PDF Service

# Para Railway (Backend):
# - DATABASE_URL debe ser la connection string de Supabase
# - FRONTEND_URL debe ser tu dominio de Vercel
# - RESEND_API_KEY habilita Resend como provider principal (recomendado, no requiere aprobación)
# - POSTMARK_SERVER_TOKEN habilita Postmark como provider alternativo
# - EMAIL_FROM debe coincidir con un remitente/dominio válido en tu proveedor
# - EMAIL_SERVER_* son opcionales si querés mantener compatibilidad SMTP
# - OPENAI_API_KEY debe ser tu clave de OpenAI
