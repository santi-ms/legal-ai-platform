{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "DATABASE_URL",
        "API_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_PDF_SERVICE_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_INACTIVITY_MINUTES",
        "NEXT_PUBLIC_DEBUG",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "EMAIL_FROM",
        "CONTACT_TO_EMAIL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
