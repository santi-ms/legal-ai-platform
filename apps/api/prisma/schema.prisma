datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String      @id @default(uuid())
  name      String
  users     User[]
  documents Document[]
  clients   Client[]
  logs      IAUsageLog[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model User {
  id            String   @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String   @unique
  passwordHash  String   @map("password") // Mapeado a columna "password" existente en DB
  emailVerified DateTime?
  emailVerificationCodeHash String?
  emailVerificationExpiresAt DateTime?
  emailVerificationAttempts Int @default(0)
  emailVerificationLastSentAt DateTime?
  emailVerificationResendAfter DateTime?
  company       String?
  role          String   @default("user")
  professionalRole String?
  tenantId      String?
  
  // Profile fields
  bio                   String?  // Biografía profesional
  notificationPreferences Json?   // Preferencias de notificación (JSON)

  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  documentsCreated Document[] @relation("CreatedByUser")
  clientsCreated   Client[]   @relation("ClientsCreatedBy")
  accounts         Account[]
  sessions         Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("User") // Si la tabla real es "User" (creada por migraciones), quitá esta línea si es "users"
}

model Document {
  id             String            @id @default(uuid())

  // relación con Tenant
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  // quién lo creó (User)
  createdById    String
  createdBy      User              @relation("CreatedByUser", fields: [createdById], references: [id])

  type           String            // ej: "contrato_servicios"
  jurisdiccion   String            // ej: "corrientes_capital"
  tono           String            // ej: "comercial_claro"
  estado         String            // "generated_text" | "ready_pdf" | "error"
  costUsd        Float?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  versions       DocumentVersion[]
  logs           IAUsageLog[]      @relation("DocLogs") // 👈 inversa a IAUsageLog.document
}

model DocumentVersion {
  id              String    @id @default(uuid())

  documentId      String
  document        Document  @relation(fields: [documentId], references: [id])

  versionNumber   Int
  rawText         String    // Contenido original generado por IA (inmutable)
  editedContent   String?   // Contenido editado manualmente por el usuario (nullable)
  pdfUrl          String?
  hashSha256      String?
  generatedBy     String    // "gpt-5", "claude", etc.
  
  // New structured data fields (nullable for backward compatibility)
  structuredData      Json?     // Structured document data (user input)
  clausePlan          Json?     // Plan of clauses to include
  generationWarnings  Json?     // Pre-generation warnings (semantic validation rules)
  outputWarnings      Json?     // Post-generation warnings (placeholder/completeness detection)
  templateVersion     String?   // Version of template used
  status              String?   // "draft" | "generated" | "reviewed" | "final" | "needs_review"
  
  createdAt       DateTime  @default(now())
}


model Client {
  id             String   @id @default(uuid())

  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  createdById    String
  createdBy      User     @relation("ClientsCreatedBy", fields: [createdById], references: [id])

  // Tipo: "persona_fisica" | "persona_juridica"
  type           String   @default("persona_fisica")

  // Identificación
  name           String
  documentType   String?  // "DNI" | "CUIT" | "CUIL" | "Pasaporte"
  documentNumber String?

  // Contacto
  email          String?
  phone          String?

  // Domicilio
  address        String?
  city           String?
  province       String?

  // Notas internas del estudio
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model IAUsageLog {
  id               String   @id @default(uuid())

  // Relación con Tenant
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  // Relación opcional con Document
  documentId       String?
  document         Document? @relation("DocLogs", fields: [documentId], references: [id])

  service          String   // "draft-service" | "review-service"
  modelName        String   // "gpt-5"
  promptTokens     Int
  completionTokens Int
  costUsd          Float
  timestamp        DateTime @default(now())
}

// NextAuth models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


